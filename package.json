{
  "name": "wikisubmission-discord-private",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf ./build",
    "build": "pnpm run clean && tsc",
    "start": "pnpm run build && node build/index.js $*",
    "update-types": "npx supabase gen types --lang=typescript --project-id lbubcoodmaimkadoessn --schema internal > src/types/generated/database.types.ts",
    "dev": "tsx watch src/index.ts",
    "sync-api": "cp ../ws-backend/openapi.yaml src/api/openapi.yaml",
    "generate": "openapi-typescript src/api/openapi.yaml -o src/api/types.gen.ts"
  },
  "engines": {
    "node": ">=20.18.1"
  },
  "keywords": [],
  "author": "WikiSubmission",
  "license": "MIT",
  "type": "commonjs",
  "skipLibCheck": true,
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "date-fns": "^4.3.0",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "minimist": "^1.2.8",
    "node-cache": "^5.1.2",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "openapi-typescript": "^7.13.0",
    "supabase": "^2.101.0",
    "tsx": "^4.22.3"
  }
}
